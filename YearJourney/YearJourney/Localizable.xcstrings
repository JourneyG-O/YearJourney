        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Compris" } },
        "id" : { "stringUnit" : { "state" : "translated", "value" : "Mengerti" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "わかりました" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "알겠어요" } },
