    "onboarding.page1.subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Journey hat etwas Besonderes versteckt.\nSchau, was auf dich wartet." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Journey's been hiding something special.\nSee what's waiting for you." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Journey ha estado guardando algo especial.\nDescubre qué te espera." } },
        "es-MX" : { "stringUnit" : { "state" : "translated", "value" : "Journey ha estado guardando algo especial.\nDescubre qué te está esperando." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Journey cachait quelque chose de spécial.\nDécouvre ce qui t'attend." } },
        "id" : { "stringUnit" : { "state" : "translated", "value" : "Journey menyimpan sesuatu yang spesial.\nLihat apa yang menantimu." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "Journeyがずっと隠してきた特別なものがあります。\n何が待っているか見てみましょう。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "저니가 특별한 무언가를 숨기고 있었어요.\n무엇이 기다리고 있는지 확인해보세요." } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Journey esteve guardando algo especial.\nVeja o que está te esperando." } },
        "pt-PT" : { "stringUnit" : { "state" : "translated", "value" : "Journey tem guardado algo especial.\nVê o que está à tua espera." } },
        "th" : { "stringUnit" : { "state" : "translated", "value" : "Journey ซ่อนสิ่งพิเศษไว้ให้คุณ\nมาดูกันว่ามีอะไรรออยู่" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "Journey一直藏着一个惊喜。\n来看看等待你的是什么吧。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "Journey一直藏著一個驚喜。\n來看看等待你的是什麼吧。" } }
      }
    },
    "onboarding.page2.subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Zähle Geburtstage, Reisen und mehr herunter.\nDein Begleiter erinnert dich direkt im Widget." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Count down to birthdays, trips, and more.\nYour companion will remind you right on your widget." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Cuenta atrás para cumpleaños, viajes y más.\nTu compañero te avisará directamente en el widget." } },
        "es-MX" : { "stringUnit" : { "state" : "translated", "value" : "Cuenta regresiva para cumpleaños, viajes y más.\nTu compañero te avisará directo en el widget." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Compte à rebours pour les anniversaires, les voyages et bien plus.\nTon compagnon te rappellera directement sur le widget." } },
        "id" : { "stringUnit" : { "state" : "translated", "value" : "Hitung mundur ulang tahun, liburan, dan momen penting lainnya.\nTemanmu akan mengingatkan langsung di widget." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "誕生日や旅行など、大切な日をカウントダウン。\n仲間がウィジェットでお知らせします。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "생일, 여행, 그 외 소중한 날들을 카운트다운하세요.\n친구들이 위젯에서 바로 알려드려요." } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Faça contagem regressiva para aniversários, viagens e muito mais.\nSeu companheiro vai te lembrar direto no widget." } },
        "pt-PT" : { "stringUnit" : { "state" : "translated", "value" : "Faz contagem decrescente para aniversários, viagens e muito mais.\nO teu companheiro avisa-te diretamente no widget." } },
        "th" : { "stringUnit" : { "state" : "translated", "value" : "นับถอยหลังวันเกิด ทริปท่องเที่ยว และอีกมากมาย\nเพื่อนของคุณจะแจ้งเตือนตรงบน Widget" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "倒计时生日、旅行和更多重要日子。\n你的伙伴会直接在小组件上提醒你。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "倒數生日、旅行和更多重要日子。\n你的夥伴會直接在小工具上提醒你。" } }
      }
    },
    "onboarding.page3.subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Journey hat ein neues Abenteuer unter Wasser entdeckt.\nSchalte neue Begleiter mit dem Journey Pass frei." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Journey found a new adventure underwater.\nUnlock new companions with Journey Pass." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Journey encontró una nueva aventura bajo el agua.\nDesbloquea nuevos compañeros con Journey Pass." } },
        "es-MX" : { "stringUnit" : { "state" : "translated", "value" : "Journey encontró una nueva aventura bajo el agua.\nDesbloquea nuevos compañeros con Journey Pass." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Journey a trouvé une nouvelle aventure sous l'eau.\nDébloque de nouveaux compagnons avec Journey Pass." } },
        "id" : { "stringUnit" : { "state" : "translated", "value" : "Journey menemukan petualangan baru di bawah laut.\nBuka teman baru dengan Journey Pass." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "Journeyが水中で新しい冒険を見つけました。\nJourney Passで新しい仲間を迎えよう。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "저니가 물속에서 새로운 모험을 시작했어요.\nJourney Pass로 새로운 친구들을 만나보세요." } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Journey encontrou uma nova aventura no fundo do mar.\nDesbloqueie novos companheiros com o Journey Pass." } },
        "pt-PT" : { "stringUnit" : { "state" : "translated", "value" : "Journey encontrou uma nova aventura no fundo do mar.\nDesbloqueia novos companheiros com o Journey Pass." } },
        "th" : { "stringUnit" : { "state" : "translated", "value" : "Journey พบการผจญภัยใหม่ใต้น้ำ\nปลดล็อกเพื่อนใหม่ด้วย Journey Pass" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "Journey在水下找到了新的冒险。\n用Journey Pass解锁新伙伴吧。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "Journey在水中找到了新的冒險。\n用Journey Pass解鎖新夥伴吧。" } }
      }
    },
    "onboarding.page4.body.free" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Ich entwickle Year Journey als Einzelentwickler und hoffe, dass es dein Jahr ein bisschen schöner macht.\n\nFür den Preis eines Kaffees macht der Journey Pass jedes Jahr noch besser. Versprochen! Und er hilft mir sehr, weiterzumachen. Danke, dass du dabei bist." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "I'm working hard on Year Journey as a solo developer, and I hope it makes your year a little brighter.\n\nFor the price of a single coffee, Journey Pass will make every year even better. I promise! Plus, it really helps me keep going. Thanks for using my app, and thanks for being part of it." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Soy desarrollador independiente y trabajo duro en Year Journey para que tu año sea un poco mejor.\n\nPor el precio de un café, Journey Pass hará que cada año sea aún más especial. ¡Lo prometo! Y me ayuda mucho a seguir adelante. Gracias por usar la app y por estar aquí." } },
        "es-MX" : { "stringUnit" : { "state" : "translated", "value" : "Soy desarrollador independiente y le echo muchas ganas a Year Journey para que tu año sea un poco mejor.\n\nPor el precio de un café, Journey Pass hará cada año aún mejor. ¡Lo prometo! Y me ayuda a seguir adelante. Gracias por usar mi app y ser parte de esto." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Je développe Year Journey seul et j'espère qu'il rend ton année un peu plus belle.\n\nPour le prix d'un café, Journey Pass rendra chaque année encore meilleure. Promis ! Et ça m'aide vraiment à continuer. Merci d'utiliser mon app et de faire partie de l'aventure." } },
        "id" : { "stringUnit" : { "state" : "translated", "value" : "Saya mengembangkan Year Journey sendirian dan berharap app ini bisa membuat tahunmu sedikit lebih menyenangkan.\n\nSeharga secangkir kopi, Journey Pass akan membuat setiap tahun jadi lebih seru. Janji! Dan itu sangat membantu saya untuk terus mengembangkan app ini. Terima kasih sudah menggunakan app ini." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ひとりの開発者として、Year Journeyを一生懸命作っています。あなたの1年が少しでも明るくなれば嬉しいです。\n\nコーヒー1杯分の価格で、Journey Passがあなたの毎年をもっと豊かにしてくれます。間違いありません！そして、開発を続ける大きな励みになります。使っていただいて、ありがとうございます。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "1인 개발자로서 Year Journey를 열심히 만들고 있어요. 여러분의 한 해가 조금 더 빛나길 바라며요.\n\n커피 한 잔 값으로 Journey Pass를 구매하면 매년 더 풍성한 여정을 즐길 수 있어요. 정말이에요! 그리고 개발을 계속할 수 있는 큰 힘이 돼요. 함께해 주셔서 감사합니다." } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Sou desenvolvedor independente e trabalho muito no Year Journey com o desejo de que ele deixe o seu ano um pouco melhor.\n\nPelo preço de um cafezinho, o Journey Pass vai deixar cada ano ainda mais especial. Prometo! E me ajuda a continuar desenvolvendo. Obrigado por usar meu app e fazer parte disso." } },
        "pt-PT" : { "stringUnit" : { "state" : "translated", "value" : "Sou um programador independente e estou a trabalhar arduamente no Year Journey, na esperança de que o teu ano fique um pouco mais especial.\n\nPelo preço de um café, o Journey Pass vai tornar cada ano ainda melhor. Prometo! E ajuda-me muito a continuar. Obrigado por usares a minha app e por fazeres parte disto." } },
        "th" : { "stringUnit" : { "state" : "translated", "value" : "ผมพัฒนา Year Journey คนเดียว และหวังว่ามันจะทำให้ปีของคุณดีขึ้นสักนิด\n\nในราคาแค่กาแฟหนึ่งแก้ว Journey Pass จะทำให้ทุกปีของคุณดีขึ้น สัญญาเลย! และยังช่วยให้ผมมีกำลังใจในการพัฒนาต่อไปด้วย ขอบคุณที่ใช้แอปของผมนะครับ" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "我是一名独立开发者，正在努力打造Year Journey，希望它能让你的每一年更加美好。\n\n只需一杯咖啡的价格，Journey Pass就能让你的每一年更加充实。保证让你觉得值得！它也是我继续开发的动力。感谢你的使用，感谢你的陪伴。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "我是一名獨立開發者，正努力打造Year Journey，希望能讓你的每一年更加美好。\n\n只需一杯咖啡的價格，Journey Pass就能讓你的每一年更加豐富。保證讓你覺得值得！這也是我繼續開發的動力。感謝你的使用，感謝你的陪伴。" } }
      }
    },
    "onboarding.page4.body.paid" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Ich entwickle Year Journey als Einzelentwickler und hoffe, dass es dein Jahr ein bisschen schöner macht.\n\nDu hast bereits den Journey Pass. Das bedeutet mir wirklich viel, und ich gebe weiterhin mein Bestes, um Year Journey für dich noch besser zu machen." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "I'm working hard on Year Journey as a solo developer, and I hope it makes your year a little brighter.\n\nYou already have Journey Pass. It's a huge help, and I'll keep doing my best to make Year Journey even better for you." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Soy desarrollador independiente y trabajo duro en Year Journey para que tu año sea un poco mejor.\n\nYa tienes Journey Pass. Es una gran ayuda y seguiré esforzándome para mejorar la app." } },
        "es-MX" : { "stringUnit" : { "state" : "translated", "value" : "Soy desarrollador independiente y le echo muchas ganas a Year Journey para que tu año sea un poco mejor.\n\nYa tienes Journey Pass. Es de gran ayuda y seguiré dando lo mejor para mejorar la app." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Je développe Year Journey seul et j'espère qu'il rend ton année un peu plus belle.\n\nTu as déjà Journey Pass. C'est une aide précieuse et je continuerai à faire de mon mieux pour améliorer l'app." } },
        "id" : { "stringUnit" : { "state" : "translated", "value" : "Saya mengembangkan Year Journey sendirian dan berharap app ini bisa membuat tahunmu sedikit lebih menyenangkan.\n\nKamu sudah punya Journey Pass. Itu sangat berarti bagi saya, dan saya akan terus berusaha membuat Year Journey makin baik." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ひとりの開発者として、Year Journeyを一生懸命作っています。あなたの1年が少しでも明るくなれば嬉しいです。\n\nすでにJourney Passをご利用中ですね。本当に心強いです。これからもYear Journeyをもっと良くしていけるよう頑張ります。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "1인 개발자로서 Year Journey를 열심히 만들고 있어요. 여러분의 한 해가 조금 더 빛나길 바라며요.\n\n이미 Journey Pass를 이용 중이시네요. 정말 큰 힘이 돼요. 앞으로도 더 좋은 앱을 만들기 위해 최선을 다할게요." } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Sou desenvolvedor independente e trabalho muito no Year Journey com o desejo de que ele deixe o seu ano um pouco melhor.\n\nVocê já tem o Journey Pass. Isso me ajuda demais e vou continuar me esforçando para tornar o Year Journey ainda melhor pra você." } },
        "pt-PT" : { "stringUnit" : { "state" : "translated", "value" : "Sou um programador independente e estou a trabalhar arduamente no Year Journey, na esperança de que o teu ano fique um pouco mais especial.\n\nJá tens o Journey Pass. É uma grande ajuda e vou continuar a dar o meu melhor para tornar o Year Journey ainda melhor para ti." } },
        "th" : { "stringUnit" : { "state" : "translated", "value" : "ผมพัฒนา Year Journey คนเดียว และหวังว่ามันจะทำให้ปีของคุณดีขึ้นสักนิด\n\nคุณมี Journey Pass แล้ว ขอบคุณมากนะครับ มันเป็นกำลังใจที่ยิ่งใหญ่มาก และผมจะพยายามทำให้ Year Journey ดีขึ้นเรื่อยๆ" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "我是一名独立开发者，正在努力打造Year Journey，希望它能让你的每一年更加美好。\n\n你已经拥有了Journey Pass，这对我真的很有帮助。我会继续努力，让Year Journey变得更好。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "我是一名獨立開發者，正努力打造Year Journey，希望能讓你的每一年更加美好。\n\n你已經擁有Journey Pass，這對我真的很有幫助。我會繼續努力，讓Year Journey變得更好。" } }
      }
    },
