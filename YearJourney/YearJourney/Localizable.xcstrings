    "onboarding.page1.subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Journey möchte dir etwas zeigen.\nSchau, was auf dich wartet."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Looks like Journey has something to share.\nSee what's waiting for you."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Parece que Journey tiene algo que mostrarte.\nDescubre qué te espera."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Parece que Journey tiene algo que mostrarte.\nDescubre qué te está esperando."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "On dirait que Journey a quelque chose à te montrer.\nDécouvre ce qui t'attend."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sepertinya Journey ingin menunjukkan sesuatu.\nLihat apa yang menantimu."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Journeyが見せたいものがあるみたい。\n何が待っているか見てみましょう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "저니가 보여주고 싶은 게 있나 봐요.\n무슨 내용인지 확인해보세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Parece que Journey tem algo para te mostrar.\nVeja o que está te esperando."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Parece que Journey tem algo para te mostrar.\nVê o que está à tua espera."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Journey ดูเหมือนจะมีอะไรอยากบอก\nมาดูกันว่ามีอะไรรออยู่"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Journey好像有什么想给你看的。\n来看看等待你的是什么吧。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Journey好像有什麼想給你看的。\n來看看等待你的是什麼吧。"
          }
        }
      }
    },
    "onboarding.page2.subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zähle Geburtstage, Reisen und mehr herunter.\nDein Begleiter erinnert dich direkt im Widget."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Count down to birthdays, trips, and more.\nYour companion will remind you right on your widget."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuenta atrás para cumpleaños, viajes y más.\nTu compañero te avisará directamente en el widget."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuenta regresiva para cumpleaños, viajes y más.\nTu compañero te avisará directo en el widget."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Compte à rebours pour les anniversaires, les voyages et bien plus.\nTon compagnon te rappellera directement sur le widget."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hitung mundur ulang tahun, liburan, dan momen penting lainnya.\nTemanmu akan mengingatkan langsung di widget."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "誕生日や旅行など、大切な日をカウントダウン。\n仲間がウィジェットでお知らせします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "생일, 여행, 그 외 소중한 날들을 카운트다운하세요.\n친구들이 위젯에서 바로 알려드려요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Faça contagem regressiva para aniversários, viagens e muito mais.\nSeu companheiro vai te lembrar direto no widget."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Faz contagem decrescente para aniversários, viagens e muito mais.\nO teu companheiro avisa-te diretamente no widget."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "นับถอยหลังวันเกิด ทริปท่องเที่ยว และอีกมากมาย\nเพื่อนของคุณจะแจ้งเตือนตรงบน Widget"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "倒计时生日、旅行和更多重要日子。\n你的伙伴会直接在小组件上提醒你。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "倒數生日、旅行和更多重要日子。\n你的夥伴會直接在小工具上提醒你。"
          }
        }
      }
    },
    "onboarding.page3.subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Journey hat ein neues Abenteuer unter Wasser entdeckt.\nSchalte neue Begleiter mit dem Journey Pass frei."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Journey found a new adventure underwater.\nUnlock new companions with Journey Pass."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Journey encontró una nueva aventura bajo el agua.\nDesbloquea nuevos compañeros con Journey Pass."
