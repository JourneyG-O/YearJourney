    "onboarding.page4.body.free" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese App wird von einem Einzelentwickler mit viel Liebe gemacht und betreut, in der Hoffnung, dein Jahr ein bisschen heller zu machen.\n\nProbier den Journey Pass für eine noch reichere Reise.\n\nFür weniger als den Preis eines Kaffees erhältst du lebenslangen Zugang!\n\nIch werde weiterhin dafür sorgen, dass du diese App gerne behältst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This app is made and run with care by a solo developer, hoping it makes your year a little brighter.\n\nTry Journey Pass for an even richer journey.\n\nIt's less than the price of a coffee for lifetime access!\n\nI'll keep making it an app worth keeping around."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esta app está hecha y mantenida con cariño por un desarrollador independiente, con la esperanza de que tu año sea un poco más brillante.\n\nPrueba Journey Pass para vivir un viaje aún más completo.\n\n¡Por menos del precio de un café, tendrás acceso de por vida!\n\nSeguiré trabajando para que sea una app que quieras tener siempre cerca."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esta app está hecha y se mantiene con cariño por un desarrollador independiente, con la esperanza de que tu año sea un poco mejor.\n\nPrueba Journey Pass para disfrutar un viaje todavía más completo.\n\n¡Por menos de lo que cuesta un café, tendrás acceso de por vida!\n\nSeguiré esforzándome para que sea una app que quieras tener siempre a la mano."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cette appli est conçue et entretenue avec soin par un développeur indépendant, dans l'espoir de rendre ton année un peu plus belle.\n\nDécouvre Journey Pass pour un voyage encore plus riche.\n\nPour moins que le prix d'un café, profite-en à vie !\n\nJe continuerai à en faire une appli que tu auras envie de garder."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aplikasi ini dibuat dan dikelola dengan sepenuh hati oleh seorang developer independen, dengan harapan bisa membuat tahunmu sedikit lebih cerah.\n\nCoba Journey Pass untuk perjalanan yang lebih lengkap.\n\nDengan harga kurang dari secangkir kopi, dapatkan akses seumur hidup!\n\nAku akan terus berusaha membuat aplikasi ini jadi favoritmu."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このアプリは、あなたの一年が少しでも輝くようにと、個人開発者が愛情を込めて作り、運営しています。\n\nJourney Passで、もっと豊かな旅を体験してみてください。\n\nコーヒー1杯分にも満たない価格で、一生使えます！\n\nこれからもずっと使いたくなるアプリになるよう頑張ります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "여러분의 한 해가 조금 더 빛나길 바라며 1인 개발자가 애정을 담아 만들고 운영하는 앱이에요.\n\nJourney Pass를 통해 더 풍성한 여정을 경험해 보세요.\n\n커피 한 잔도 안 되는 값으로 평생 이용할 수 있어요!\n\n늘 곁에 두고 싶은 좋은 앱으로 보답하겠습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este app é feito e mantido com carinho por um desenvolvedor independente, na esperança de tornar o seu ano um pouco mais especial.\n\nExperimente o Journey Pass para uma jornada ainda mais completa.\n\nPor menos que o preço de um café, tenha acesso vitalício!\n\nVou continuar trabalhando para que este seja um app que você queira manter sempre por perto."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esta app é feita e mantida com dedicação por um programador independente, com a esperança de tornar o teu ano um pouco mais especial.\n\nExperimenta o Journey Pass para uma jornada ainda mais completa.\n\nPor menos do que o preço de um café, tens acesso para toda a vida!\n\nVou continuar a trabalhar para que esta seja uma app que queiras manter sempre por perto."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "แอปนี้สร้างและดูแลด้วยความใส่ใจโดยนักพัฒนาคนเดียว ด้วยความหวังว่าจะทำให้ปีนี้ของคุณสดใสขึ้นอีกนิด\n\nลองสัมผัสการเดินทางที่อิ่มเอมยิ่งขึ้นด้วย Journey Pass\n\nในราคาที่ถูกกว่ากาแฟหนึ่งแก้ว ใช้งานได้ตลอดชีพ!\n\nจะพยายามทำให้แอปนี้เป็นแอปที่คุณอยากเก็บไว้ใช้ตลอดไปนะ"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这是一位独立开发者用心制作并持续运营的应用，希望能让你的这一年多一点闪光。\n\n试试 Journey Pass，体验更丰富的旅程。\n\n不到一杯咖啡的价格，即可终身使用！\n\n我会继续努力，把它做成一款你愿意一直留在身边的应用。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這是一位獨立開發者用心製作並持續營運的應用程式，希望能讓你的這一年多一點閃光。\n\n試試 Journey Pass，體驗更豐富的旅程。\n\n不到一杯咖啡的價格，即可終身使用！\n\n我會繼續努力，把它做成一款你願意一直留在身邊的應用程式。"
          }
        }
      }
    },
