        "en" : { "stringUnit" : { "state" : "translated", "value" : "Saved! 🎉" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "¡Guardado! 🎉" } },
        "es-MX" : { "stringUnit" : { "state" : "translated", "value" : "¡Guardado! 🎉" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Enregistré ! 🎉" } },
        "id" : { "stringUnit" : { "state" : "translated", "value" : "Tersimpan! 🎉" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "保存しました！🎉" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "저장됐어요! 🎉" } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Salvo! 🎉" } },
        "pt-PT" : { "stringUnit" : { "state" : "translated", "value" : "Guardado! 🎉" } },
        "th" : { "stringUnit" : { "state" : "translated", "value" : "บันทึกแล้ว! 🎉" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "已保存！🎉" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "已儲存！🎉" } }
      }
    },
    "alert.dday.saved.upgrade" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Journey Pass holen" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Get Journey Pass" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Conseguir Journey Pass" } },
        "es-MX" : { "stringUnit" : { "state" : "translated", "value" : "Obtener Journey Pass" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Obtenir Journey Pass" } },
        "id" : { "stringUnit" : { "state" : "translated", "value" : "Dapatkan Journey Pass" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "Journey Passを購入" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "Journey Pass 구매하기" } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Obter Journey Pass" } },
        "pt-PT" : { "stringUnit" : { "state" : "translated", "value" : "Obter Journey Pass" } },
        "th" : { "stringUnit" : { "state" : "translated", "value" : "รับ Journey Pass" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "获取Journey Pass" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "取得Journey Pass" } }
      }
