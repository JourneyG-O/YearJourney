    "alert.dday.saved.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Dein D-Day ist jetzt in der App sichtbar.\nFür die Anzeige im Widget benötigst du einen Journey Pass." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Your D-Day is now visible in the app.\nTo show the bubble in your widget, you'll need a Journey Pass." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Tu D-Day ya es visible en la app.\nPara mostrarlo en el widget necesitas Journey Pass." } },
        "es-MX" : { "stringUnit" : { "state" : "translated", "value" : "Tu D-Day ya se ve en la app.\nPara mostrarlo en el widget necesitas Journey Pass." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Ton D-Day est maintenant visible dans l'app.\nPour l'afficher dans le widget, tu as besoin du Journey Pass." } },
        "id" : { "stringUnit" : { "state" : "translated", "value" : "D-Day kamu kini terlihat di app.\nUntuk menampilkannya di widget, kamu perlu Journey Pass." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "D-Dayがアプリで確認できるようになりました。\nウィジェットにも表示するにはJourney Passが必要です。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "D-Day가 앱에서 확인할 수 있어요.\n위젯에서 버블로 표시하려면 Journey Pass가 필요해요." } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Seu D-Day já está visível no app.\nPara exibir a bolha no widget, você precisará do Journey Pass." } },
        "pt-PT" : { "stringUnit" : { "state" : "translated", "value" : "O teu D-Day já está visível na app.\nPara mostrares a bolha no widget, precisas do Journey Pass." } },
        "th" : { "stringUnit" : { "state" : "translated", "value" : "D-Day ของคุณแสดงในแอปแล้ว\nหากต้องการแสดงบน Widget ต้องใช้ Journey Pass" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "你的D-Day现在可以在应用中查看了。\n要在小组件中显示气泡，需要Journey Pass。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "你的D-Day現在可以在應用程式中查看了。\n要在小工具中顯示氣泡，需要Journey Pass。" } }
      }
    },
    "alert.dday.saved.title" : {
