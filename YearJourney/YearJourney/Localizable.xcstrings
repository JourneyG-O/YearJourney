          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "저니가 물속에서 새로운 모험을 시작했어요.\nJourney Pass로 새로운 친구들을 만나보세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Journey encontrou uma nova aventura no fundo do mar.\nDesbloqueie novos companheiros com o Journey Pass."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Journey encontrou uma nova aventura no fundo do mar.\nDesbloqueia novos companheiros com o Journey Pass."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Journey พบการผจญภัยใหม่ใต้น้ำ\nปลดล็อกเพื่อนใหม่ด้วย Journey Pass"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Journey在水下找到了新的冒险。\n用Journey Pass解锁新伙伴吧。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Journey在水中找到了新的冒險。\n用Journey Pass解鎖新夥伴吧。"
          }
        }
