    "alert.dday.saved.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dein D-Day ist jetzt in der App sichtbar.\nUm ihn auch im Widget anzuzeigen, benötigst du einen Journey Pass."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your D-Day is now visible in the app.\nTo show it on your widget too, you'll need Journey Pass."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu D-Day ya es visible en la app.\nPara mostrarlo también en el widget, necesitas Journey Pass."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu D-Day ya se ve en la app.\nPara mostrarlo también en el widget, necesitas Journey Pass."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ton D-Day est maintenant visible dans l'app.\nPour l'afficher aussi sur ton widget, tu as besoin du Journey Pass."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "D-Day kamu kini terlihat di app.\nUntuk menampilkannya juga di widget, kamu perlu Journey Pass."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "D-Dayがアプリで確認できるようになりました。\nウィジェットにも表示したい場合は、Journey Passが必要です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "D-Day가 앱에서 확인할 수 있어요.\n위젯에도 표시하려면 Journey Pass가 필요해요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seu D-Day já está visível no app.\nPara exibi-lo também no widget, você precisará do Journey Pass."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O teu D-Day já está visível na app.\nPara o mostrares também no widget, precisas do Journey Pass."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "D-Day ของคุณแสดงในแอปแล้ว\nหากต้องการแสดงบน Widget ด้วย ต้องใช้ Journey Pass"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的D-Day现在可以在应用中查看了。\n想在小组件上也显示的话，需要Journey Pass。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的D-Day現在可以在應用程式中查看了。\n想在小工具上也顯示的話，需要Journey Pass。"
          }
        }
      }
    },
